{
  "name": "taxi-line-platform",
  "version": "0.0.1",
  "private": true,
  "description": "Smart taxi line system for West Bank cities",
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx --cache",
    "lint:fix": "eslint . --ext .ts,.tsx --cache --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "corepack pnpm -r run typecheck",
    "firebase:node20": "node ./scripts/run-firebase-node20.cjs",
    "emulators:core": "node ./scripts/run-firebase-node20.cjs emulators:start --only auth,firestore,functions",
    "emulators": "node ./scripts/run-firebase-node20.cjs emulators:start",
    "emulators:persist": "node ./scripts/run-firebase-node20.cjs emulators:start --import=./emulator-data --export-on-exit=./emulator-data",
    "build:functions": "corepack pnpm --filter @taxi-line/functions build",
    "qa:driver-eligibility:e2e": "corepack pnpm --filter @taxi-line/functions qa:driver-eligibility:e2e",
    "qa:driver-eligibility:e2e:exec": "node ./scripts/run-firebase-node20.cjs emulators:exec --project waselneh-prod-414e2 --only auth,firestore,functions \"node backend/functions/scripts/qa-driver-eligibility-e2e.mjs\"",
    "backfill:driver-eligibility:dry-run": "corepack pnpm --filter @taxi-line/functions backfill:driver-eligibility -- --project waselneh-prod-414e2",
    "backfill:driver-eligibility:apply": "corepack pnpm --filter @taxi-line/functions backfill:driver-eligibility:apply -- --project waselneh-prod-414e2",
    "deploy:prod": "node ./scripts/run-firebase-node20.cjs deploy --project waselneh-prod-414e2 --only functions,firestore:rules",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "dependencies": {
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
